{
    "editor.fontFamily": "Inconsolata, Menlo, Monaco, 'Courier New', monospace",
    "editor.fontSize": 18,
    "editor.minimap.enabled": false,
    "editor.rulers": [
        120
    ],
    "workbench.colorTheme": "Solarized Dark",
    "git.confirmSync": false,
    "git.autofetch": true,
    "files.autoSave": "onFocusChange",
    "editor.wordWrapColumn": 120,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "breadcrumbs.enabled": true,
    "search.smartCase": true,
    "search.quickOpen.includeSymbols": true,
    "vs-kubernetes": {
        "vs-kubernetes.kubectl-path": "$HOME/.vs-kubernetes/tools/kubectl/kubectl",
        "vs-kubernetes.helm-path": "$HOME/.vs-kubernetes/tools/helm/darwin-amd64/helm",
        "vs-kubernetes.draft-path": "$HOME/.vs-kubernetes/tools/draft/darwin-amd64/draft",
        "vs-kubernetes.minikube-path": "$HOME/.vs-kubernetes/tools/minikube/darwin-amd64/minikube",
        "vs-kubernetes.minikube-path.mac": "$HOME/.vs-kubernetes/tools/minikube/darwin-amd64/minikube",
        "vscode-kubernetes.kubectl-path.mac": "$HOME/.vs-kubernetes/tools/kubectl/kubectl",
        "vscode-kubernetes.helm-path.mac": "$HOME/.vs-kubernetes/tools/helm/darwin-arm64/helm",
        "vscode-kubernetes.minikube-path.mac": "$HOME/.vs-kubernetes/tools/minikube/darwin-arm64/minikube"
    },
    "[haskell]": {
        "editor.defaultFormatter": "sjurmillidahl.ormolu-vscode"
    },
    "[go]": {
        "editor.snippetSuggestions": "none",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": true
        }
    },
    "files.eol": "\n",
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "editor.suggestSelection": "first",
    "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
    "files.exclude": {
        "**/.classpath": true,
        "**/.project": true,
        "**/.settings": true,
        "**/.factorypath": true
    },
    "yaml.format.enable": false,
    "C_Cpp.updateChannel": "Insiders",
    "atomKeymap.promptV3Features": true,
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.formatOnPaste": true,
    "[rust]": {
        "editor.defaultFormatter": "rust-lang.rust"
    },
    "terraform.languageServer": {
        "external": true,
        "args": [
            "serve"
        ]
    },
    "ghcSimple.replCommand": "cabal new-repl semantic",
    "ghcSimple.inlineRepl.loadType": "object-code",
    "go.formatTool": "goimports",
    "go.useLanguageServer": true,
    "python.languageServer": "Pylance",
    "[python]": {
        "editor.defaultFormatter": "mikoz.black-py",
        "editor.formatOnType": true
    },
    "workbench.settings.openDefaultKeybindings": true,
    "vscode-neovim.neovimExecutablePaths.darwin": "/opt/homebrew/bin/nvim",
    "workbench.editorAssociations": {
        "*.ipynb": "jupyter.notebook.ipynb"
    },
    "workbench.editor.untitled.hint": "hidden",
    "codeQL.telemetry.enableTelemetry": false,
    "ghcSimple.trustedReplCommandConfigs": {
        "$HOME/github/dotfiles": "cabal new-repl semantic"
    },
    "idris.executablePath": "idris2",
    "redhat.telemetry.enabled": false,
    "[css]": {
        "editor.suggest.insertMode": "replace",
        "gitlens.codeLens.scopes": [
            "document"
        ]
    },
    "css.format.enable": false,
    "python.venvFolders": [
        "$HOME/.cache/pypoetry/virtualenvs/",
        "$HOME/Library/Caches/pypoetry/virtualenvs/app-wS8lqT4F-py3.10"
    ],
    "emmet.showExpandedAbbreviation": "never",
    "emmet.preferences": {},
}
