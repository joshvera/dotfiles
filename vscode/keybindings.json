// VSCode keybindings with Neovim integration
[
    // ============================================================================
    // Neovim Mode-Specific Bindings
    // ============================================================================

    // Cmd+/ in visual mode -> send to neovim for commenting
    {
        "key": "cmd+/",
        "command": "vscode-neovim.send",
        "when": "editorTextFocus && neovim.init && neovim.mode == visual",
        "args": "<C-/>"
    },

    // Ctrl+T in normal mode -> navigate back (like vim's Ctrl+O)
    {
        "key": "ctrl+t",
        "command": "workbench.action.navigateBack",
        "when": "editorTextFocus && neovim.mode == 'normal'"
    },

    // ============================================================================
    // Disable VSCode defaults that conflict with Neovim
    // ============================================================================

    // Disable Ctrl+T transpose letters (let neovim handle it)
    {
        "key": "ctrl+t",
        "command": "-editor.action.transposeLetters",
        "when": "textInputFocus && !editorReadonly"
    },

    // Disable Ctrl+D deleteRight in insert mode (let neovim handle it)
    {
        "key": "ctrl+d",
        "command": "-deleteRight",
        "when": "editorTextFocus && neovim.mode == 'insert'"
    },

    // Disable Ctrl+F page down in neovim modes (let neovim handle it)
    {
        "key": "ctrl+f",
        "command": "-vscode-neovim.ctrl-f",
        "when": "editorTextFocus && neovim.ctrlKeysNormal && neovim.init && neovim.mode != 'insert'"
    },

    // ============================================================================
    // UI Bindings
    // ============================================================================

    // Alt+Cmd+O to toggle sidebar (instead of Cmd+B)
    {
        "key": "alt+cmd+o",
        "command": "workbench.action.toggleSidebarVisibility"
    },
    {
        "key": "cmd+b",
        "command": "-workbench.action.toggleSidebarVisibility"
    },

    // Align code
    {
        "key": "ctrl+cmd+=",
        "command": "wwm.aligncode"
    }
]
