#!/bin/zsh
# Remove git worktree and branch

if [ -z "$1" ]; then
  echo "Usage: remove-work <branch-name>"
  return 1
fi

local branch_name="$1"
local project_name branch_dir worktree_name worktree_path
project_name=$(basename -s .git "$(git config --get remote.origin.url)")
branch_dir=${branch_name//\//-}  # Replace '/' with '-' for valid directory names
worktree_name="${project_name}-${branch_dir}"
worktree_path="../$worktree_name"

# Check for legacy unsanitized path as well
local legacy_worktree_name legacy_worktree_path actual_worktree_path
legacy_worktree_name="${project_name}-${branch_name}"
legacy_worktree_path="../$legacy_worktree_name"

if [ -d "$worktree_path" ]; then
  actual_worktree_path="$worktree_path"
  echo "Found worktree: $worktree_path"
elif [ -d "$legacy_worktree_path" ]; then
  actual_worktree_path="$legacy_worktree_path"
  echo "Found legacy worktree: $legacy_worktree_path"
else
  echo "No worktree found for branch '$branch_name'"
  echo "Checking if branch exists locally..."
  if git show-ref --verify --quiet "refs/heads/$branch_name"; then
    echo "Branch '$branch_name' exists locally, removing..."
    git branch -D "$branch_name"
    return $?
  else
    echo "Branch '$branch_name' not found"
    return 1
  fi
fi

# Remove the worktree (this also removes the branch if it's only in the worktree)
echo "Removing worktree: $actual_worktree_path"
git worktree remove "$actual_worktree_path"
local worktree_exit=$?

# Check if branch still exists and remove it
if [ $worktree_exit -eq 0 ]; then
  if git show-ref --verify --quiet "refs/heads/$branch_name"; then
    echo "Removing branch: $branch_name"
    git branch -D "$branch_name"
  fi
  echo "Successfully removed worktree and branch '$branch_name'"
else
  echo "Failed to remove worktree"
  return 1
fi